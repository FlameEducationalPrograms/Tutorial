/* ============================================================
   STATE & NAVIGATION
============================================================ */
let currentRole = null, currentStep = 0, totalSteps = 0;

function selectRoleAndGo(role) {
  currentRole = role; currentStep = 0;
  const data = TUTORIALS[role]; totalSteps = data.steps.length;
  
  const badge = document.getElementById('role-badge');
  badge.classList.remove('hidden'); badge.classList.add('active');
  document.getElementById('role-badge-text').textContent = data.name;
  
  document.getElementById('sidebar-dot').style.background = data.color;
  document.getElementById('sidebar-role-name').textContent = data.name + ' Tutorial';
  
  // Display the step content
  buildSidebarSteps(); 
  renderStep(); 
  
  // Unhide the tutorial container and smoothly scroll to it
  const tutorialPage = document.getElementById('page-tutorial');
  tutorialPage.classList.add('active');
  document.getElementById('step-nav').style.display = 'flex';
  tutorialPage.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function buildSidebarSteps() {
  const data = TUTORIALS[currentRole], list = document.getElementById('sidebar-steps-list');
  list.innerHTML = '';
  data.steps.forEach((step, idx) => {
    const item = document.createElement('div');
    item.className = 'sidebar-step-item' + (idx === currentStep ? ' active' : '') + (idx < currentStep ? ' completed' : '');
    item.onclick = () => jumpToStep(idx);
    item.innerHTML = `<div class="step-num">${idx < currentStep ? '✓' : idx + 1}</div><span class="step-label">${step.title}</span>`;
    list.appendChild(item);
  });
}

function updateSidebar() {
  document.querySelectorAll('.sidebar-step-item').forEach((item, idx) => {
    item.className = 'sidebar-step-item' + (idx < currentStep ? ' completed' : '') + (idx === currentStep ? ' active' : '');
    item.querySelector('.step-num').textContent = idx < currentStep ? '✓' : idx + 1;
  });
}

function jumpToStep(idx) { 
  currentStep = idx; 
  renderStep(); 
  document.getElementById('page-tutorial').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function renderStep() {
  const step = TUTORIALS[currentRole].steps[currentStep];
  const isLast = currentStep === totalSteps - 1, isFirst = currentStep === 0;
  
  document.getElementById('progress-fill').style.width = ((currentStep + 1) / totalSteps * 100).toFixed(0) + '%';
  document.getElementById('progress-count').textContent = `${currentStep + 1} / ${totalSteps}`;
  document.getElementById('progress-label').textContent = step.title;
  document.getElementById('step-counter').textContent = `${currentStep + 1} / ${totalSteps}`;
  
  document.getElementById('btn-prev').style.visibility = isFirst ? 'hidden' : 'visible';
  const btnNext = document.getElementById('btn-next');
  if (isLast) { btnNext.textContent = '🎉 Complete!'; btnNext.onclick = showCompletion; } 
  else { btnNext.innerHTML = 'Next →'; btnNext.onclick = nextStep; }
  
  document.getElementById('step-content').innerHTML = `
    <div class="step-card slide-up">
      <div class="step-card-header">
        <div class="step-card-icon" style="background:${step.iconBg}">${step.icon}</div>
        <div><div class="step-card-title">${step.title}</div><div class="step-card-subtitle">${step.subtitle}</div></div>
      </div>
      <div class="step-card-body">${step.content}</div>
    </div>
  `;
  
  updateSidebar();
}

function nextStep() { 
  if (currentStep < totalSteps - 1) { 
    currentStep++; 
    renderStep(); 
    document.getElementById('page-tutorial').scrollIntoView({ behavior: 'smooth', block: 'start' });
  } 
}

function prevStep() { 
  if (currentStep > 0) { 
    currentStep--; 
    renderStep(); 
    document.getElementById('page-tutorial').scrollIntoView({ behavior: 'smooth', block: 'start' });
  } 
}

function showCompletion() {
  document.getElementById('step-content').innerHTML = `
    <div class="step-card slide-up" style="text-align:center; padding:48px 24px;">
      <span style="font-size:64px; display:block; margin-bottom:16px;">🎉</span>
      <h2 style="font-size:1.6rem; font-weight:800; margin-bottom:10px;">Tutorial Complete!</h2>
      <p style="color:var(--text-secondary); margin-bottom:28px;">You've completed the ${TUTORIALS[currentRole].name} guide.</p>
      <div style="display:flex; gap:12px; justify-content:center;">
        <button style="padding:12px 24px; border-radius:10px; background:var(--bg-panel); font-weight:600;" onclick="jumpToStep(0)">↩ Restart</button>
        <button style="padding:12px 24px; border-radius:10px; background:var(--blue); color:#fff; font-weight:600;" onclick="document.getElementById('page-roles').scrollIntoView({behavior: 'smooth'})">Try Another Role</button>
      </div>
    </div>
  `;
  document.getElementById('step-nav').style.display = 'none';
  document.getElementById('page-tutorial').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

/* ============================================================
   UTILITIES
============================================================ */
function toggleTheme() {
  const html = document.documentElement;
  const isDark = html.getAttribute('data-theme') === 'dark';
  html.setAttribute('data-theme', isDark ? 'light' : 'dark');
  document.getElementById('theme-icon').textContent = isDark ? '🌙' : '☀️';
}
function closeOnboarding() {
  const overlay = document.getElementById('onboarding-overlay');
  overlay.style.opacity = '0'; setTimeout(() => overlay.remove(), 300);
}
